<?xml version="1.0"?>
<sdf version="1.9">
  <world name="medipick_pharmacy_textured">
    <plugin filename="ignition-gazebo-physics-system" name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system" name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system" name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="ignition-gazebo-imu-system" name="ignition::gazebo::systems::Imu"/>
    <plugin filename="ignition-gazebo-contact-system" name="ignition::gazebo::systems::Contact"/>

    <gravity>0 0 -9.8</gravity>

    <scene>
      <ambient>0.74 0.75 0.77 1</ambient>
      <background>0.95 0.96 0.98 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 12 0 0 0</pose>
      <diffuse>0.88 0.88 0.86 1</diffuse>
      <specular>0.25 0.25 0.25 1</specular>
      <direction>-0.45 0.18 -0.88</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>18 14</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>18 14</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.84 0.85 0.84 1</ambient>
            <diffuse>0.90 0.91 0.90 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="room_shell">
      <static>true</static>
      <link name="walls">
        <collision name="back_wall_collision">
          <pose>8.85 0 1.55 0 0 0</pose>
          <geometry><box><size>0.24 9.20 3.10</size></box></geometry>
        </collision>
        <collision name="left_wall_collision">
          <pose>4.35 4.65 1.55 0 0 0</pose>
          <geometry><box><size>9.20 0.24 3.10</size></box></geometry>
        </collision>
        <collision name="right_wall_collision">
          <pose>4.35 -4.65 1.55 0 0 0</pose>
          <geometry><box><size>9.20 0.24 3.10</size></box></geometry>
        </collision>
        <visual name="back_wall_visual">
          <pose>8.85 0 1.55 0 0 0</pose>
          <geometry><box><size>0.24 9.20 3.10</size></box></geometry>
          <material><ambient>0.96 0.97 0.98 1</ambient><diffuse>0.99 0.99 1.0 1</diffuse></material>
        </visual>
        <visual name="left_wall_visual">
          <pose>4.35 4.65 1.55 0 0 0</pose>
          <geometry><box><size>9.20 0.24 3.10</size></box></geometry>
          <material><ambient>0.96 0.97 0.98 1</ambient><diffuse>0.99 0.99 1.0 1</diffuse></material>
        </visual>
        <visual name="right_wall_visual">
          <pose>4.35 -4.65 1.55 0 0 0</pose>
          <geometry><box><size>9.20 0.24 3.10</size></box></geometry>
          <material><ambient>0.96 0.97 0.98 1</ambient><diffuse>0.99 0.99 1.0 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Back wall shelves -->
    <include><name>back_shelf_01</name><uri>model://pharmacy_shelf_dense</uri><pose>7.45 -3.45 0 0 0 0</pose></include>
    <include><name>back_shelf_02</name><uri>model://pharmacy_shelf</uri><pose>7.45 -2.20 0 0 0 0</pose></include>
    <include><name>back_shelf_03</name><uri>model://pharmacy_shelf_compact</uri><pose>7.45 -0.95 0 0 0 0</pose></include>
    <include><name>back_shelf_04</name><uri>model://pharmacy_shelf_dense</uri><pose>7.45 0.35 0 0 0 0</pose></include>
    <include><name>back_shelf_05</name><uri>model://pharmacy_shelf</uri><pose>7.45 1.70 0 0 0 0</pose></include>
    <include><name>back_shelf_06</name><uri>model://pharmacy_shelf_compact</uri><pose>7.45 3.00 0 0 0 0</pose></include>

    <!-- Aisle A -->
    <include><name>aisle_a_left_01</name><uri>model://pharmacy_shelf_dense</uri><pose>5.70 -2.85 0 0 0 0</pose></include>
    <include><name>aisle_a_left_02</name><uri>model://pharmacy_shelf_compact</uri><pose>5.70 -1.45 0 0 0 0</pose></include>
    <!-- 中央总过道：这里留空，方便机器人横向穿行并再拐入各排货架 -->
    <include><name>aisle_a_left_04</name><uri>model://pharmacy_shelf_dense</uri><pose>5.70 1.55 0 0 0 0</pose></include>
    <include><name>aisle_a_left_05</name><uri>model://pharmacy_shelf_compact</uri><pose>5.70 3.00 0 0 0 0</pose></include>

    <include><name>aisle_a_right_01</name><uri>model://pharmacy_shelf</uri><pose>4.00 -2.80 0 0 0 3.141592653589793</pose></include>
    <include><name>aisle_a_right_02</name><uri>model://pharmacy_shelf_dense</uri><pose>4.00 -1.35 0 0 0 3.141592653589793</pose></include>
    <!-- 中央总过道：这里留空，方便机器人横向穿行并再拐入各排货架 -->
    <include><name>aisle_a_right_04</name><uri>model://pharmacy_shelf</uri><pose>4.00 1.55 0 0 0 3.141592653589793</pose></include>
    <include><name>aisle_a_right_05</name><uri>model://pharmacy_shelf_dense</uri><pose>4.00 3.05 0 0 0 3.141592653589793</pose></include>

    <!-- Aisle B -->
    <include><name>aisle_b_left_01</name><uri>model://pharmacy_shelf_compact</uri><pose>3.00 -2.95 0 0 0 0</pose></include>
    <include><name>aisle_b_left_02</name><uri>model://pharmacy_shelf</uri><pose>3.00 -1.50 0 0 0 0</pose></include>
    <!-- 中央总过道：这里留空，方便机器人横向穿行并再拐入各排货架 -->
    <include><name>aisle_b_left_04</name><uri>model://pharmacy_shelf_compact</uri><pose>3.00 1.45 0 0 0 0</pose></include>
    <include><name>aisle_b_left_05</name><uri>model://pharmacy_shelf</uri><pose>3.00 2.95 0 0 0 0</pose></include>

    <include><name>aisle_b_right_01</name><uri>model://pharmacy_shelf_dense</uri><pose>1.30 -2.90 0 0 0 3.141592653589793</pose></include>
    <include><name>aisle_b_right_02</name><uri>model://pharmacy_shelf_compact</uri><pose>1.30 -1.45 0 0 0 3.141592653589793</pose></include>
    <!-- 中央总过道：这里留空，交互药盒簇已经转移到 aisle_b_right_04 -->
    <include><name>aisle_b_right_04</name><uri>model://pharmacy_shelf_dense</uri><pose>1.30 1.50 0 0 0 3.141592653589793</pose></include>
    <include><name>aisle_b_right_05</name><uri>model://pharmacy_shelf_compact</uri><pose>1.30 3.00 0 0 0 3.141592653589793</pose></include>

    <!-- Endcap displays -->
    <include><name>endcap_a_top</name><uri>model://pharmacy_endcap_display</uri><pose>4.85 4.00 0 0 0 1.5707963267948966</pose></include>
    <include><name>endcap_a_bottom</name><uri>model://pharmacy_endcap_display</uri><pose>4.85 -4.00 0 0 0 -1.5707963267948966</pose></include>
    <include><name>endcap_b_top</name><uri>model://pharmacy_endcap_display</uri><pose>2.15 4.00 0 0 0 1.5707963267948966</pose></include>
    <include><name>endcap_b_bottom</name><uri>model://pharmacy_endcap_display</uri><pose>2.15 -4.00 0 0 0 -1.5707963267948966</pose></include>

