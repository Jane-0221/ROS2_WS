<?xml version="1.0" encoding="utf-8"?>
<robot name="simple5_urdf">
  <link name="world" />
  <link name="base_x_link" />
  <link name="base_y_link" />
  <link name="base_theta_link" />

  <joint name="base_x" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="world" />
    <child link="base_x_link" />
    <axis xyz="1 0 0" />
    <limit lower="-100.0" upper="100.0" effort="400.0" velocity="2.0" />
  </joint>

  <joint name="base_y" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
