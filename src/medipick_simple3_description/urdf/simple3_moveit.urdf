<?xml version="1.0" encoding="utf-8"?>
<robot name="simple4_urdf">
  <link name="world" />
  <link name="base_x_link" />
  <link name="base_y_link" />
  <link name="base_theta_link" />
  <link name="base_roll_link" />

  <joint name="base_x" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="world" />
    <child link="base_x_link" />
    <axis xyz="1 0 0" />
    <limit lower="-3.0" upper="3.0" effort="400.0" velocity="1.0" />
  </joint>

  <joint name="base_y" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_x_link" />
    <child link="base_y_link" />
    <axis xyz="0 1 0" />
    <limit lower="-3.0" upper="3.0" effort="400.0" velocity="1.0" />
  </joint>

  <joint name="base_theta" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_y_link" />
    <child link="base_theta_link" />
    <axis xyz="0 0 1" />
    <limit lower="-3.141592653589793" upper="3.141592653589793" effort="150.0" velocity="1.57" />
  </joint>

  <!-- Align the exported simple4 body frame with the project convention: +X forward, +Z up. -->
  <joint name="base_roll_mount" type="fixed">
    <origin xyz="0 0 0" rpy="3.141592653589793 0 0" />
    <parent link="base_theta_link" />
    <child link="base_roll_link" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-4.7835E-16 0.0033916 -0.11843" rpy="0 0 0" />
      <mass value="26.422" />
      <inertia ixx="0.38775" ixy="1.3079E-17" ixz="-7.5307E-17" iyy="0.39408" iyz="-0.0017998" izz="0.53185" />
