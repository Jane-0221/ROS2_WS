    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://medipick_simple3_description/meshes/simple4_urdf/base_link.STL" />
      </geometry>
      <material name="base_blue">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
