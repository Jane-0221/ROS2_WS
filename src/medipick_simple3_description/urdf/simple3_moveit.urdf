        <mesh filename="package://medipick_simple3_description/meshes/simple4_urdf/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="base_heading_mount" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 1.5707963267948966" />
    <parent link="base_roll_link" />
    <child link="base_link" />
  </joint>

