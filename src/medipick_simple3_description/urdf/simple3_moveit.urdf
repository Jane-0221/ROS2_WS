    <child link="base_theta_link" />
    <axis xyz="0 0 1" />
    <limit effort="150.0" velocity="3.14" />
  </joint>

  <joint name="base_mount" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_theta_link" />
    <child link="base_link" />
  </joint>

  <link name="base_link">
