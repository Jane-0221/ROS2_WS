[Unit]
Description=MediPick Wheeltec Chassis Controller
After=network.target dev-ttyACM0.device medipick-stm32.service
Wants=network.target dev-ttyACM0.device medipick-stm32.service
PartOf=medipick-stm32-base-chain.target

[Service]
Type=simple
User=jszn
Group=jszn
WorkingDirectory=/home/jszn/robot_ros2_ws
Environment=HOME=/home/jszn
Environment=ROS_DISTRO=humble
ExecStart=/bin/bash -lc 'source /opt/ros/humble/setup.bash && source /home/jszn/robot_ros2_ws/install/setup.bash && exec ros2 run robot_hardware wheeltec_chassis_node --ros-args -p protocol:=serial -p robot_type:=omni -p port:=/dev/ttyACM0 -p baudrate:=115200 -p cmd_vel_topic:=/medipick/hardware/stm32_base_cmd_vel -p publish_odom:=false -p publish_battery:=false -p disable_software_limit:=true -p cmd_timeout:=0.2'
Restart=always
RestartSec=2
KillSignal=SIGINT
TimeoutStopSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=medipick-stm32-base-chain.target
